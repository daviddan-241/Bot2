# ─────────────────────────────────────────────────────────────
# FlowAI — Environment Variables
# Copy to server/.env  OR  paste into Render → Environment tab
# ─────────────────────────────────────────────────────────────

# ── Email: Gmail App Password (FREE, no OAuth needed) ─────────
# Step 1: Enable 2-Step Verification on your Google account
# Step 2: Go to myaccount.google.com → Security → App Passwords
# Step 3: Create an App Password for "Mail"
# Step 4: Paste the 16-char password (spaces don't matter)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=FlowAI <you@gmail.com>
EMAIL_QUEUE_DELAY_MS=2500

# ── AI: Groq (FREE — 14,400 requests/day, no credit card) ────
# Get key at console.groq.com → sign up → API Keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# ── AI: Ollama (FREE, 100% offline — local use only) ──────────
# Install: ollama.ai → run: ollama pull llama3
# Leave default on Render — rule engine handles offline there
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3

# ── Lead Discovery: Serper (FREE — 2,500 searches/month) ──────
# Get key at serper.dev — no credit card needed
SERPER_API_KEY=

# ── Lead Discovery: Brave Search (FREE — 2,000/month) ─────────
# Get key at api.search.brave.com — free tier
BRAVE_SEARCH_API_KEY=

# OpenStreetMap is ALWAYS ON — no key needed, truly free

# ── Server ─────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
PORT=3001
NODE_ENV=production
DB_PATH=./data/flowai.sqlite
CORS_ORIGIN=https://your-app.onrender.com
DEFAULT_COUNTRY=US
