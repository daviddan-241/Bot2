# Server
PORT=5000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
DB_PATH=./data/leadflow.sqlite
CORS_ORIGIN=http://localhost:5173
DEFAULT_COUNTRY=US

# AI priority: Ollama -> Groq -> HuggingFace -> rule engine
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Legal search APIs. At least one is required for lead discovery.
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=
BING_SEARCH_API_KEY=

# SMTP for real email sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="LeadFlow AI <you@example.com>"
EMAIL_QUEUE_DELAY_MS=2500

# WhatsApp Cloud API for real sends. Without this, app generates wa.me click links.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
# Optional custom/approved validation endpoint if you have one
WHATSAPP_VERIFY_URL=
